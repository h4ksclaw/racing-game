# Sketchfab API
SKETCHFAB_API_KEY=

# S3 / MinIO
S3_ENDPOINT=https://s3-api.t3ks.com
S3_BUCKET=game-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true
S3_SKIP_TLS_VERIFY=true  # set to false in production with valid certs

# Server
PORT=3001
DB_PATH=./data/game_assets.db
ASSET_DIR=./data/assets
