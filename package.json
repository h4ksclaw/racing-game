{
  "name": "racing-game",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 0.0.0.0 --port 3000",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx src/server/index.ts",
    "preview": "node dist/server/index.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && biome check src/ && bash scripts/knip.sh",
    "fix": "biome check --write src/ && tsc --noEmit",
    "prepare": "husky",
    "knip": "bash scripts/knip.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/three": "^0.183.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^5.0.0",
    "lint-staged": "^15.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "@aws-sdk/s3-request-presigner": "^3.1034.0",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fuse.js": "^7.3.0",
    "lit": "^3.3.2",
    "multer": "^2.1.1",
    "simplex-noise": "^4.0.3",
    "three": "^0.183.2"
  }
}
